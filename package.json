{
  "name": "teams-card-apiserver",
  "version": "0.1.0",
  "description": "Universal Teams card API server — receives webhooks (Radarr, Sonarr, Plex, ...) and translates them into Microsoft Teams cards.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "express": "^5.1.0",
    "multer": "^2.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
